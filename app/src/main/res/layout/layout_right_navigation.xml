<?xml version="1.0" encoding="utf-8"?>
<!-- Ether side drawer — end-gravity, full-height. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ether_bg_1"
    android:fitsSystemWindows="true"
    android:paddingTop="24dp">

    <!-- Drawer header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/ether_space_16"
        android:layout_marginBottom="4dp"
        android:textAppearance="@style/TextAppearance.Ether.Label"
        android:text="CHOOSE LOCATION" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/ether_space_16"
        android:layout_marginBottom="@dimen/ether_space_16"
        android:textAppearance="@style/TextAppearance.Ether.Title"
        android:textStyle="bold"
        android:text="Where to next?" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ether_border_low"
        android:layout_marginStart="@dimen/ether_space_16"
        android:layout_marginEnd="@dimen/ether_space_16"
        android:layout_marginBottom="@dimen/ether_space_8" />

    <!-- Server list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/serverListRv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/server_list_view" />


</LinearLayout>
