<?xml version="1.0" encoding="utf-8"?>
<!-- Ether StatusChrome toolbar — replaces the old AppBarLayout+Toolbar stack. -->
<!-- IDs navbar_left, navbar_right, and toolbar are preserved for VpnDock.java. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/ether_chrome_height">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageButton
            android:id="@+id/navbar_left"
            android:layout_width="@dimen/ether_icon_btn_size"
            android:layout_height="@dimen/ether_icon_btn_size"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/cd_menu"
            android:padding="8dp"
            android:src="@drawable/ic_menu"
            android:scaleType="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="@dimen/ether_space_16" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ether_app_title"
            android:textAppearance="@style/TextAppearance.Ether.ChromeTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/navbar_right"
            android:layout_width="@dimen/ether_icon_btn_size"
            android:layout_height="@dimen/ether_icon_btn_size"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/cd_locations"
            android:padding="8dp"
            android:src="@drawable/ic_globe"
            android:scaleType="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="@dimen/ether_space_16" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
