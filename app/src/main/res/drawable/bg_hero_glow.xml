<?xml version="1.0" encoding="utf-8"?>
<!-- Glowing rounded square container for logos/marks on login + about screens -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ether_accent_surface" />
    <stroke android:width="1dp" android:color="@color/ether_accent_glow" />
    <corners android:radius="20dp" />
</shape>
