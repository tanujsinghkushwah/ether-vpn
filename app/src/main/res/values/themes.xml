<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.EtherVPN" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Material3 primary = Ether violet accent -->
        <item name="colorPrimary">@color/ether_accent</item>
        <item name="colorOnPrimary">@color/ether_bg_0</item>
        <item name="colorPrimaryContainer">@color/ether_accent_surface</item>
        <item name="colorOnPrimaryContainer">@color/ether_text_primary</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/ether_bg_0</item>
        <item name="colorSurface">@color/ether_bg_1</item>
        <item name="colorOnSurface">@color/ether_text_primary</item>
        <item name="colorSurfaceVariant">@color/ether_surface_med</item>
        <item name="colorOnSurfaceVariant">@color/ether_text_secondary</item>

        <!-- System bars — transparent, edge-to-edge -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowBackground">@color/ether_bg_0</item>

        <!-- No action bar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Custom Ether accent attr -->
        <item name="etherAccent">@color/ether_accent</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/ether_surface_high</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/ether_text_primary</item>
        <item name="android:textColorSecondary">@color/ether_text_secondary</item>

        <!-- Widget overrides -->
        <item name="materialButtonStyle">@style/Widget.Ether.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.Ether.TextInput</item>
    </style>

</resources>
